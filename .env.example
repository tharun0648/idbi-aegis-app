# Aegis LLM narrator (OPTIONAL). Groq, OpenAI-compatible endpoint.
# Absent/empty → the narrator is off: businessNarrative is null and the app
# renders exactly as it does without it. Never commit a real key.
GROQ_API_KEY=

# Optional model override. Defaults to openai/gpt-oss-120b (GA), with a runtime
# fallback to openai/gpt-oss-20b if the primary is unavailable on the account.
# GROQ_MODEL=openai/gpt-oss-120b
